    {
      "id": "IIdViYkywj-hmytlP5N3K",
      "type": "text",
      "x": 745.6310646047191,
      "y": 1730.273107556594,
      "width": 980,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
